@page "/"
@page "/products"
@page "/products/category/{Category}"
@using EShop.Web.Models
@using EShop.Web.Services
@inject ICatalogService CatalogService
@inject IBasketService BasketService

<PageTitle>EShop - Products</PageTitle>

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col">
            <h2><i class="bi bi-shop"></i> Product Catalog</h2>
        </div>
    </div>

    <!-- Category Filter -->
    <div class="row mb-4">
        <div class="col">
            <div class="btn-group" role="group">
                <a href="/products" class="btn @(string.IsNullOrEmpty(Category) ? "btn-primary" : "btn-outline-primary")">All</a>
                <a href="/products/category/Smartphones" class="btn @(Category == "Smartphones" ? "btn-primary" : "btn-outline-primary")">Smartphones</a>
                <a href="/products/category/Electronics" class="btn @(Category == "Electronics" ? "btn-primary" : "btn-outline-primary")">Electronics</a>
                <a href="/products/category/Laptops" class="btn @(Category == "Laptops" ? "btn-primary" : "btn-outline-primary")">Laptops</a>
                <a href="/products/category/Audio" class="btn @(Category == "Audio" ? "btn-primary" : "btn-outline-primary")">Audio</a>
                <a href="/products/category/Accessories" class="btn @(Category == "Accessories" ? "btn-primary" : "btn-outline-primary")">Accessories</a>
            </div>
        </div>
    </div>

    @if (_loading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="alert alert-danger">
            <i class="bi bi-exclamation-triangle"></i> @_errorMessage
            <button class="btn btn-sm btn-outline-danger ms-3" @onclick="Retry">Retry</button>
        </div>
    }
    else if (_products.Count == 0)
    {
        <div class="alert alert-info">No products found.</div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            @foreach (var product in _products)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm">
                        <div class="card-img-top bg-light text-center p-4" style="height: 200px; display: flex; align-items: center; justify-content: center;">
                            <i class="bi bi-box-seam" style="font-size: 4rem; color: #6c757d;"></i>
                        </div>
                        <div class="card-body">
                            <h5 class="card-title">@product.Name</h5>
                            <p class="card-text text-muted">@product.Description</p>
                            <div class="mb-2">
                                @foreach (var cat in product.Category)
                                {
                                    <span class="badge bg-info me-1">@cat</span>
                                }
                            </div>
                            <h4 class="text-primary">$@(product.Price.ToString("N2"))</h4>
                        </div>
                        <div class="card-footer bg-white border-top-0">
                            <button class="btn btn-success w-100" @onclick="() => AddToCart(product)">
                                <i class="bi bi-cart-plus"></i> Add to Cart
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@if (_showToast)
{
    <div class="position-fixed bottom-0 end-0 p-3" style="z-index: 1050;">
        <div class="toast show align-items-center text-bg-success border-0">
            <div class="d-flex">
                <div class="toast-body">
                    <i class="bi bi-check-circle"></i> @_toastMessage
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" @onclick="() => _showToast = false"></button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string? Category { get; set; }

    private List<ProductModel> _products = [];
    private bool _loading = true;
    private bool _showToast;
    private string _toastMessage = "";
    private string? _errorMessage;
    private const string UserName = "john_doe";

    protected override async Task OnParametersSetAsync()
    {
        await LoadProducts();
    }

    private async Task LoadProducts()
    {
        _loading = true;
        _errorMessage = null;
        try
        {
            _products = string.IsNullOrEmpty(Category)
                ? await CatalogService.GetProducts()
                : await CatalogService.GetProductsByCategory(Category);
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to load products. The Catalog service may be unavailable. ({ex.GetType().Name})";
            _products = [];
        }
        _loading = false;
    }

    private async Task Retry()
    {
        await LoadProducts();
    }

    private async Task AddToCart(ProductModel product)
    {
        var cart = await BasketService.GetBasket(UserName);

        var existingItem = cart.Items.FirstOrDefault(x => x.ProductId == product.Id);
        if (existingItem != null)
        {
            existingItem.Quantity++;
        }
        else
        {
            cart.Items.Add(new ShoppingCartItem
            {
                ProductId = product.Id,
                ProductName = product.Name,
                Price = product.Price,
                Quantity = 1,
                Color = "Default"
            });
        }

        cart.UserName = UserName;
        await BasketService.StoreBasket(cart);

        _toastMessage = $"{product.Name} added to cart!";
        _showToast = true;
        StateHasChanged();

        _ = Task.Delay(3000).ContinueWith(_ =>
        {
            _showToast = false;
            InvokeAsync(StateHasChanged);
        });
    }
}
