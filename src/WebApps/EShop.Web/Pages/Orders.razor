@page "/orders"
@using EShop.Web.Models
@using EShop.Web.Services
@inject IOrderService OrderService

<PageTitle>EShop - My Orders</PageTitle>

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col">
            <h2><i class="bi bi-list-check"></i> My Orders</h2>
        </div>
    </div>

    @if (_loading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="alert alert-danger">
            <i class="bi bi-exclamation-triangle"></i> @_errorMessage
        </div>
    }
    else if (_orders.Count == 0)
    {
        <div class="text-center py-5">
            <i class="bi bi-inbox" style="font-size: 4rem; color: #6c757d;"></i>
            <h4 class="mt-3 text-muted">No orders yet</h4>
            <a href="/products" class="btn btn-primary mt-3">
                <i class="bi bi-shop"></i> Start Shopping
            </a>
        </div>
    }
    else
    {
        @foreach (var order in _orders)
        {
            <div class="card shadow-sm mb-4">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <div>
                        <strong>@order.OrderName</strong>
                        <small class="text-muted ms-2">ID: @order.Id.ToString()[..8]...</small>
                    </div>
                    <span class="badge @OrderStatusHelper.GetStatusBadgeClass(order.Status)">
                        @OrderStatusHelper.GetStatusText(order.Status)
                    </span>
                </div>
                <div class="card-body">
                    <div class="row">
                        <!-- Items -->
                        <div class="col-md-6">
                            <h6 class="text-muted mb-2">Items</h6>
                            <table class="table table-sm">
                                <thead>
                                    <tr>
                                        <th>Product</th>
                                        <th class="text-center">Qty</th>
                                        <th class="text-end">Price</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in order.OrderItems)
                                    {
                                        <tr>
                                            <td>@item.ProductName</td>
                                            <td class="text-center">@item.Quantity</td>
                                            <td class="text-end">$@(item.Price.ToString("N2"))</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        <!-- Shipping -->
                        <div class="col-md-3">
                            <h6 class="text-muted mb-2">Shipping To</h6>
                            <p class="mb-0">
                                @order.ShippingAddress.FirstName @order.ShippingAddress.LastName<br>
                                @order.ShippingAddress.AddressLine<br>
                                @order.ShippingAddress.State, @order.ShippingAddress.ZipCode<br>
                                @order.ShippingAddress.Country
                            </p>
                        </div>

                        <!-- Total -->
                        <div class="col-md-3 text-end">
                            <h6 class="text-muted mb-2">Total</h6>
                            <h4 class="text-primary">$@(order.TotalPrice.ToString("N2"))</h4>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
</div>

@code {
    private List<OrderModel> _orders = [];
    private bool _loading = true;
    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        _loading = true;
        try
        {
            _orders = await OrderService.GetOrders();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to load orders. ({ex.GetType().Name})";
            _orders = [];
        }
        _loading = false;
    }
}
