@page "/checkout"
@using EShop.Web.Models
@using EShop.Web.Services
@inject IBasketService BasketService
@inject IOrderService OrderService
@inject ICheckoutSagaOrchestrator SagaOrchestrator
@inject NavigationManager Navigation

<PageTitle>EShop - Checkout</PageTitle>

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col">
            <h2><i class="bi bi-credit-card"></i> Checkout</h2>
        </div>
    </div>

    @if (_orderPlaced)
    {
        <div class="text-center py-5">
            <div class="mb-4">
                <i class="bi bi-check-circle-fill text-success" style="font-size: 5rem;"></i>
            </div>
            <h3 class="text-success">Order Placed Successfully!</h3>
            <p class="text-muted">Thank you for your purchase. Your order is being processed.</p>

            @if (_sagaResult != null)
            {
                <div class="mt-3 mx-auto" style="max-width: 400px;">
                    <h6 class="text-start"><i class="bi bi-diagram-3"></i> Saga Execution Steps:</h6>
                    <ul class="list-group list-group-flush text-start">
                        @foreach (var step in _sagaResult.Steps)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                <span>@step.Name</span>
                                <span class="badge bg-success">@step.Status</span>
                            </li>
                        }
                    </ul>
                </div>
            }

            <div class="mt-4">
                <a href="/orders" class="btn btn-primary me-2">
                    <i class="bi bi-list-check"></i> View Orders
                </a>
                <a href="/products" class="btn btn-outline-secondary">
                    <i class="bi bi-shop"></i> Continue Shopping
                </a>
            </div>
        </div>
    }
    else if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="alert alert-danger" role="alert">
            <h5><i class="bi bi-exclamation-triangle"></i> Checkout Failed</h5>
            <p>@_errorMessage</p>

            @if (_sagaResult != null)
            {
                <hr>
                <h6><i class="bi bi-diagram-3"></i> Saga Execution Log:</h6>
                <ul class="list-group list-group-flush">
                    @foreach (var step in _sagaResult.Steps)
                    {
                        var badgeClass = step.Status switch
                        {
                            SagaStepStatus.Completed => "bg-success",
                            SagaStepStatus.Failed => "bg-danger",
                            _ => "bg-warning"
                        };
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <span>@step.Name @(step.Error != null ? $"— {step.Error}" : "")</span>
                            <span class="badge @badgeClass">@step.Status</span>
                        </li>
                    }
                </ul>
            }

            <button class="btn btn-primary mt-3" @onclick="PlaceOrder">
                <i class="bi bi-arrow-clockwise"></i> Retry
            </button>
        </div>
    }
    else
    {
        <div class="row">
            <!-- Checkout Form -->
            <div class="col-lg-8">
                <div class="card shadow-sm mb-4">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="bi bi-geo-alt"></i> Shipping Address</h5>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">First Name</label>
                                <input type="text" class="form-control" @bind="_checkout.FirstName" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Last Name</label>
                                <input type="text" class="form-control" @bind="_checkout.LastName" />
                            </div>
                            <div class="col-12">
                                <label class="form-label">Email</label>
                                <input type="email" class="form-control" @bind="_checkout.EmailAddress" />
                            </div>
                            <div class="col-12">
                                <label class="form-label">Address</label>
                                <input type="text" class="form-control" @bind="_checkout.AddressLine" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Country</label>
                                <input type="text" class="form-control" @bind="_checkout.Country" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">State</label>
                                <input type="text" class="form-control" @bind="_checkout.State" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Zip Code</label>
                                <input type="text" class="form-control" @bind="_checkout.ZipCode" />
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card shadow-sm">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="bi bi-credit-card-2-front"></i> Payment Information</h5>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-12">
                                <label class="form-label">Name on Card</label>
                                <input type="text" class="form-control" @bind="_checkout.CardName" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Card Number</label>
                                <input type="text" class="form-control" @bind="_checkout.CardNumber" placeholder="4111 1111 1111 1111" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Expiration</label>
                                <input type="text" class="form-control" @bind="_checkout.Expiration" placeholder="MM/YY" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">CVV</label>
                                <input type="text" class="form-control" @bind="_checkout.Cvv" placeholder="123" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Order Summary -->
            <div class="col-lg-4">
                <div class="card shadow-sm">
                    <div class="card-header bg-dark text-white">
                        <h5 class="mb-0">Order Summary</h5>
                    </div>
                    <div class="card-body">
                        @if (_cart.Items.Count > 0)
                        {
                            @foreach (var item in _cart.Items)
                            {
                                <div class="d-flex justify-content-between mb-2">
                                    <span>@(item.ProductName) x @(item.Quantity)</span>
                                    <span>$@((item.Price * item.Quantity).ToString("N2"))</span>
                                </div>
                            }
                            <hr>
                            <div class="d-flex justify-content-between fw-bold fs-5">
                                <span>Total</span>
                                <span class="text-primary">$@(CartTotal())</span>
                            </div>
                        }
                        else
                        {
                            <p class="text-muted">Cart is empty</p>
                        }
                    </div>
                    <div class="card-footer">
                        <button class="btn btn-success w-100 btn-lg" @onclick="PlaceOrder" disabled="@(_processing || _cart.Items.Count == 0)">
                            @if (_processing)
                            {
                                <span class="spinner-border spinner-border-sm me-2"></span>
                                <span>Processing...</span>
                            }
                            else
                            {
                                <i class="bi bi-lock"></i>
                                <span> Place Order</span>
                            }
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private ShoppingCart _cart = new();
    private BasketCheckoutRequest _checkout = new()
    {
        CustomerId = Guid.Parse("d290f1ee-6c54-4b01-90e6-d701748f0851"),
        UserName = "john_doe",
        FirstName = "John",
        LastName = "Doe",
        EmailAddress = "john@example.com",
        AddressLine = "123 Main St",
        Country = "USA",
        State = "NY",
        ZipCode = "10001",
        CardName = "John Doe",
        CardNumber = "4111111111111111",
        Expiration = "12/25",
        Cvv = "123",
        PaymentMethod = 1
    };
    private bool _processing;
    private bool _orderPlaced;
    private string? _errorMessage;
    private CheckoutSagaResult? _sagaResult;
    private const string UserName = "john_doe";

    protected override async Task OnInitializedAsync()
    {
        _cart = await BasketService.GetBasket(UserName);
    }

    private async Task PlaceOrder()
    {
        _processing = true;
        _errorMessage = null;
        StateHasChanged();

        // Generate idempotency key to prevent duplicate orders on double-click/retry
        var idempotencyKey = $"{UserName}-{DateTime.UtcNow:yyyyMMdd-HHmmss}-{Guid.NewGuid():N}";

        // Build the order model
        var order = new OrderModel
        {
            Id = Guid.NewGuid(),
            CustomerId = _checkout.CustomerId,
            OrderName = $"Order-{DateTime.UtcNow:yyyyMMdd-HHmmss}",
            ShippingAddress = new AddressModel
            {
                FirstName = _checkout.FirstName,
                LastName = _checkout.LastName,
                EmailAddress = _checkout.EmailAddress,
                AddressLine = _checkout.AddressLine,
                Country = _checkout.Country,
                State = _checkout.State,
                ZipCode = _checkout.ZipCode
            },
            Payment = new PaymentModel
            {
                CardName = _checkout.CardName,
                CardNumber = _checkout.CardNumber,
                Expiration = _checkout.Expiration,
                Cvv = _checkout.Cvv,
                PaymentMethod = _checkout.PaymentMethod
            },
            Status = 1, // Pending
            OrderItems = _cart.Items.Select(item => new OrderItemModel
            {
                ProductId = GenerateGuidFromString(item.ProductId),
                ProductName = item.ProductName,
                Price = item.Price,
                Quantity = item.Quantity
            }).ToList(),
            TotalPrice = _cart.Items.Sum(x => x.Price * x.Quantity)
        };

        // Execute the Checkout Saga (with compensation on failure)
        var sagaContext = new CheckoutSagaContext
        {
            UserName = UserName,
            Order = order,
            CheckoutRequest = new BasketCheckoutRequest
            {
                UserName = UserName,
                CustomerId = _checkout.CustomerId,
                FirstName = _checkout.FirstName,
                LastName = _checkout.LastName,
                EmailAddress = _checkout.EmailAddress,
                AddressLine = _checkout.AddressLine,
                Country = _checkout.Country,
                State = _checkout.State,
                ZipCode = _checkout.ZipCode,
                CardName = _checkout.CardName,
                CardNumber = _checkout.CardNumber,
                Expiration = _checkout.Expiration,
                Cvv = _checkout.Cvv,
                PaymentMethod = _checkout.PaymentMethod
            },
            IdempotencyKey = idempotencyKey
        };

        _sagaResult = await SagaOrchestrator.ExecuteAsync(sagaContext);
        _orderPlaced = _sagaResult.IsSuccess;
        _errorMessage = _sagaResult.ErrorMessage;
        _processing = false;
        StateHasChanged();
    }

    private static Guid GenerateGuidFromString(string input)
    {
        using var md5 = System.Security.Cryptography.MD5.Create();
        var hash = md5.ComputeHash(System.Text.Encoding.UTF8.GetBytes(input));
        return new Guid(hash);
    }

    private string CartTotal() => _cart.Items.Sum(i => i.Price * i.Quantity).ToString("N2");
}
